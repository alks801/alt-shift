# AI provider configuration.
#
# Leave OPENAI_API_KEY empty to use the built-in mock generator
# (useful for local development without an API key — letters are produced
# from a deterministic template with a simulated streaming delay).
#
# When set, the /api/generate route will call OpenAI Chat Completions
# server-side, so the key never ships to the browser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Analytics measurement ID (G-XXXXXXXXXX). Leave empty in local /
# preview so dev pageviews don't pollute the production property. Set only on
# the deployed environment via Vercel project env vars.
NEXT_PUBLIC_GA_ID=
